<?xml version="1.0" encoding="UTF-8"?>
<!-- IIS / Azure: cache file tĩnh lâu (song song .htaccess trên Apache). -->
<configuration>
    <system.webServer>
        <staticContent>
            <clientCache cacheControlMode="UseMaxAge" cacheControlMaxAge="365.00:00:00" />
        </staticContent>
    </system.webServer>
</configuration>
